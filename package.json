{
  "name": "movie-cast-browser",
  "version": "0.1.0",
  "description": "A desktop browser that detects direct video URLs and casts media to Chromecast without screen mirroring.",
  "author": "thuongtin",
  "license": "MIT",
  "homepage": "https://github.com/thuongtin/movie-cast-browser#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thuongtin/movie-cast-browser.git"
  },
  "bugs": {
    "url": "https://github.com/thuongtin/movie-cast-browser/issues"
  },
  "keywords": [
    "electron",
    "chromecast",
    "cast",
    "hls",
    "m3u8",
    "video",
    "react",
    "tailwindcss",
    "desktop"
  ],
  "main": "src/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "vite build",
    "start": "node scripts/ensure-electron.js && npm run build && electron .",
    "check": "node scripts/check.js && npm run build",
    "smoke": "node scripts/ensure-electron.js && npm run build && MOVIE_CAST_BROWSER_SMOKE=1 SMOKE_OUTPUT_DIR=./smoke-output electron .",
    "test": "npm run check"
  },
  "dependencies": {
    "@foxxmd/chromecast-client": "^1.0.4",
    "@radix-ui/react-slider": "^1.4.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "bonjour-service": "^1.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^39.2.7",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.21.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.17",
    "vite": "^8.1.0"
  },
  "overrides": {
    "debug": "^4.4.3",
    "dns-packet": "^5.6.1",
    "protobufjs": "^8.6.5"
  }
}
